# ============================================================
# AML Case Management — local infrastructure environment vars
# ============================================================
# Copy this file to `.env` (gitignored) and adjust per-machine.
# ============================================================

# ─── PostgreSQL (shared instance, multiple databases) ───
POSTGRES_USER=aml_admin
POSTGRES_PASSWORD=aml_admin_pwd
POSTGRES_PORT=5432

# ─── MongoDB (mongo profile) ───
MONGO_INITDB_ROOT_USERNAME=aml_admin
MONGO_INITDB_ROOT_PASSWORD=aml_admin_pwd
MONGO_PORT=27017

# ─── Redis ───
REDIS_PASSWORD=aml_redis_pwd
REDIS_PORT=6379

# ─── Kafka (KRaft single-node) ───
KAFKA_PORT_HOST=9092
SCHEMA_REGISTRY_PORT=8081
KAFKA_UI_PORT=8090

# ─── SMTP (MailHog) ───
MAILHOG_SMTP_PORT=1025
MAILHOG_UI_PORT=8025

# ─── Observability (obs + elk profiles) ───
ELASTICSEARCH_PORT=9200
KIBANA_PORT=5601
LOGSTASH_TCP_PORT=5000
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
GRAFANA_ADMIN_PASSWORD=admin
JAEGER_UI_PORT=16686
JAEGER_OTLP_GRPC_PORT=4317
JAEGER_OTLP_HTTP_PORT=4318

# ─── Quality (qa profile) ───
SONARQUBE_PORT=9000
SONARQUBE_DB_USER=sonar
SONARQUBE_DB_PASSWORD=sonar_pwd
