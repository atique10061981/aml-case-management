# Universal editor settings — every modern IDE honors this.
# https://editorconfig.org/
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.{yml,yaml,json,md,jsonc}]
indent_size = 2

[*.{xml,xsd,xsl}]
indent_size = 4

[Makefile]
indent_style = tab
